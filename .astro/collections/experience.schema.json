{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "role": {
      "type": "string"
    },
    "company": {
      "type": "string"
    },
    "logo": {
      "type": "string"
    },
    "period": {
      "type": "string"
    },
    "description": {
      "type": "string",
      "minLength": 50
    },
    "tags": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "order": {
      "default": 0,
      "type": "number"
    },
    "isCurrent": {
      "default": false,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "role",
    "company",
    "logo",
    "period",
    "description",
    "tags"
  ]
}