{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "category": {
      "type": "string"
    },
    "icon": {
      "type": "string"
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "priority": {
      "default": 0,
      "type": "number"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "category",
    "icon",
    "skills"
  ]
}