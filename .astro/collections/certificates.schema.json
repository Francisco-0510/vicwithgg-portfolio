{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "org": {
      "type": "string"
    },
    "date": {
      "type": "string"
    },
    "logo": {
      "type": "string"
    },
    "url": {
      "anyOf": [
        {
          "type": "string",
          "format": "uri"
        },
        {
          "type": "string",
          "const": ""
        }
      ]
    },
    "credentialId": {
      "type": "string"
    },
    "expires": {
      "type": "string",
      "format": "date-time"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "org",
    "date",
    "logo",
    "url"
  ]
}