---
import { ClientRouter } from 'astro:transitions';
import MainHead from '@components/MainHead.astro';
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';

// Fuentes Variable: Descomentadas para mejorar el CLS y la estética
/* import '@fontsource-variable/inter';
import '@fontsource-variable/onest'; */

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <MainHead title={title} description={description} />
    <ClientRouter />

    <script is:inline>
      (function () {
        const theme = (() => {
          if (
            typeof localStorage !== 'undefined' &&
            localStorage.getItem('dark_mode')
          ) {
            return localStorage.getItem('dark_mode') === 'true';
          }
          return window.matchMedia('(prefers-color-scheme: dark)').matches;
        })();
        document.documentElement.classList.toggle('dark', theme);
      })();
    </script>
  </head>
  <body
    class="relative min-h-screen flex flex-col bg-white text-neutral-900 dark:bg-neutral-950 dark:text-neutral-100 antialiased transition-colors duration-500 selection:bg-blue-100 dark:selection:bg-blue-500/30">
    <div
      class="fixed inset-0 -z-10 hidden dark:block h-full w-full bg-[radial-gradient(circle_at_top,_var(--tw-gradient-stops))] from-blue-900/10 via-transparent to-transparent pointer-events-none"
      aria-hidden="true">
    </div>

    <Navbar />

    <main id="main-content" class="flex-1 w-full mx-auto max-w-5xl px-6">
      <slot />
    </main>

    <Footer />

    <script>
      import '../assets/js/main.js';

      // Si realmente necesitas el polyfill, impórtalo aquí para que Astro lo procese:
    </script>
  </body>
</html>

<style is:global>
  :root {
    /* Fuente refinada: Onest para headers, Inter para cuerpo */
    font-family: 'Inter Variable', system-ui, sans-serif;
  }

  h1,
  h2,
  h3,
  h4 {
    font-family: 'Onest Variable', system-ui, sans-serif;
    letter-spacing: -0.02em;
  }

  /* Foco accesible y estético */
  :focus-visible {
    @apply outline-none ring-2 ring-blue-500 ring-offset-2 dark:ring-offset-neutral-950 rounded-sm;
  }

  html {
    scrollbar-gutter: stable;
  }

  body {
    overscroll-behavior-y: none;
  }

  /* --- Optimizaciones para Lighthouse 100 --- */

  /* Reducir movimiento */
  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto !important;
    }
    *,
    ::before,
    ::after {
      animation-duration: 0.01ms !important;
      transition-duration: 0.01ms !important;
    }
  }

  /* Scrollbar Minimalista */
  ::-webkit-scrollbar {
    width: 8px;
  }
  ::-webkit-scrollbar-track {
    background: transparent;
  }
  ::-webkit-scrollbar-thumb {
    @apply bg-neutral-200 dark:bg-neutral-800 rounded-full border-2 border-transparent bg-clip-content;
  }
  ::-webkit-scrollbar-thumb:hover {
    @apply bg-neutral-300 dark:bg-neutral-700;
  }
</style>
