---
import MainHead from '@components/MainHead.astro';
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';

// Fuentes variables para optimización de carga
import '@fontsource-variable/inter';
import '@fontsource-variable/onest';

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <MainHead title={title} description={description} />
  </head>
  <body
    class="relative antialiased min-h-screen w-full bg-white text-neutral-900 dark:bg-neutral-950 dark:text-neutral-100 transition-colors duration-300">
    <div
      class="fixed inset-0 -z-10 hidden dark:block h-full w-full bg-[url('https://www.marval.xyz/bg-light.svg')] bg-cover opacity-20 pointer-events-none"
      aria-hidden="true">
    </div>

    <Navbar />

    <main id="main-content" class="flex-grow">
      <slot />
    </main>

    <Footer />

    <script src="../assets/js/main.js"></script>
  </body>
</html>

<style is:global>
  :root {
    /* Definición de la fuente principal del portafolio */
    font-family: 'Onest Variable', 'Inter Variable', system-ui, sans-serif;
  }

  html {
    /* Asegura que el scroll no "salte" al cambiar de sección */
    scroll-behavior: smooth;
  }

  body {
    /* Optimización de scroll en dispositivos móviles */
    overscroll-behavior: none;
    display: flex;
    flex-direction: column;
  }

  /* Respetar la preferencia de ahorro de batería o accesibilidad del sistema */
  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }
  }

  /* Estilos para la barra de scroll (opcional para consistencia visual) */
  ::-webkit-scrollbar {
    width: 8px;
  }
  ::-webkit-scrollbar-track {
    background: transparent;
  }
  ::-webkit-scrollbar-thumb {
    background: #525252;
    border-radius: 10px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #3b82f6;
  }
</style>
