---
import type { HTMLAttributes } from 'astro/types';

// Usar 'export' es clave para que index.astro reconozca estos tipos
export interface Props extends HTMLAttributes<'section'> {
  id: string; // Identificador único para el anclaje
  title?: string; // Título de la sección (opcional)
  order?: number; // Número de orden para el ScrollSpy (opcional)
}

const { id, title, order, class: className, ...props } = Astro.props;
---

<script>
  type SectionState = {
    order: number;
    target: HTMLElement;
    visible: boolean;
  };

  const updatePageLinks = (activeId: string) => {
    const documentLinks = document.querySelectorAll("a[href^='#']");
    documentLinks.forEach((link) => {
      if (link instanceof HTMLAnchorElement) {
        const targetId = link.hash.slice(1);
        // Sincronizamos con las clases de tu Navbar
        const isActive = targetId === activeId;
        link.classList.toggle('text-blue-600', isActive);
        link.classList.toggle('dark:text-blue-400', isActive);
        link.classList.toggle('font-bold', isActive);
      }
    });
  };

  document.addEventListener('astro:page-load', () => {
    const observerSections = document.querySelectorAll(
      '[data-observed-section]',
    );
    const sectionStates = new Map<string, SectionState>();

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          sectionStates.set(entry.target.id, {
            target: entry.target as HTMLElement,
            order: Number(entry.target.getAttribute('data-observed-section')),
            visible: entry.isIntersecting,
          });
        });

        // Encontrar la sección visible con el orden más alto para el ScrollSpy
        const latestVisible = Array.from(sectionStates.values())
          .filter((s) => s.visible)
          .reduce(
            (prev, curr) => (curr.order > (prev?.order ?? -1) ? curr : prev),
            null as SectionState | null,
          );

        if (latestVisible) {
          updatePageLinks(latestVisible.target.id);
        }
      },
      {
        threshold: 0.2,
        rootMargin: '-10% 0px -75% 0px',
      },
    );

    observerSections.forEach((section) => observer.observe(section));
  });
</script>

<section
  id={id}
  data-observed-section={order}
  class:list={[
    'section scroll-m-20 w-full max-w-5xl mx-auto px-4 py-16 md:py-24',
    className,
  ]}
  {...props}>
  {
    title && (
      <header class="group mb-12 flex items-center gap-4">
        <h2 class="flex items-center text-pretty font-header text-2xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100 md:text-3xl">
          {order && (
            <span class="mr-3 text-blue-600/80 dark:text-blue-400/80 font-mono text-xl md:text-2xl">
              {String(order).padStart(2, '0')}.
            </span>
          )}
          {title}
        </h2>
        <div class="h-px grow bg-neutral-200 dark:bg-neutral-800 mt-2" />
      </header>
    )
  }

  <div class="w-full">
    <slot />
  </div>
</section>
