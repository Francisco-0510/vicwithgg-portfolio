---
// src/layouts/BaseLayout.astro
import '../styles/global.css';
import { site } from '../data/portfolio';
import ClientRouter from 'astro/components/ClientRouter.astro';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import SEO from '../components/SEO.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article' | 'profile';
  keywords?: string[];
  publishedDate?: string;
  modifiedDate?: string;
  structuredData?: {
    type: 'Person' | 'Organization' | 'BreadcrumbList' | 'Project';
    data?: Record<string, any>;
  };
}

const {
  title = site.title,
  description = site.description,
  ogImage = '/og-image.jpg',
  ogType = 'website',
  keywords,
  publishedDate,
  modifiedDate,
  structuredData,
} = Astro.props;
---

<!doctype html>
<html lang={site.locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO Component -->
    <SEO
      title={title}
      description={description}
      ogImage={ogImage}
      ogType={ogType}
      keywords={keywords}
      publishedDate={publishedDate}
      modifiedDate={modifiedDate}
      canonical={Astro.url.href}
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />

    <!-- RSS autodiscovery -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${site.title} — RSS`}
      href="/rss.xml"
    />

    <!-- Preconnect -->
    <link rel="preconnect" href="https://va.vercel-scripts.com" crossorigin />

    <!-- Astro View Transitions -->
    <ClientRouter />

   {/* Structured Data JSON-LD */}
    {structuredData && structuredData.type === 'Person' && (
      <script is:inline type="application/ld+json">
        {JSON.stringify({
          "@context": "https://schema.org",
          "@type": "Person",
          "@id": site.url,
          "name": "Francisco Victorico Aguirre Jiménez",
          "alternateName": "VicWithGG",
          "url": site.url,
          "image": new URL('/images/me.jpg', site.url).href,
          "description": description,
          "jobTitle": ["Diseñador UX/UI", "Desarrollador Frontend"],
          "email": "vgg.designer.01@gmail.com",
          "telephone": "+52 1 951 391 5906",
          "address": {
            "@type": "PostalAddress",
            "addressLocality": "Oaxaca",
            "addressCountry": "MX"
          },
          "sameAs": [
            "https://github.com/Francisco-0510",
            "https://www.linkedin.com/in/vicwith-gg/",
            "https://x.com/VicWithGG1",
            "https://www.figma.com/@vicwithgg"
          ]
        })}
      </script>
    )}

    {structuredData && structuredData.type === 'Organization' && (
      <script is:inline type="application/ld+json">
        {JSON.stringify({
          "@context": "https://schema.org",
          "@type": "Organization",
          "name": "VGG Design & Dev",
          "url": site.url,
          "description": description,
          "founder": {
            "@type": "Person",
            "name": "Francisco Victorico Aguirre Jiménez"
          },
          "sameAs": [
            "https://github.com/Francisco-0510",
            "https://www.linkedin.com/in/vicwith-gg/",
            "https://x.com/VicWithGG1",
            "https://www.figma.com/@vicwithgg"
          ]
        })}
      </script>
    )}

    {!structuredData && (
      <script is:inline type="application/ld+json">
        {JSON.stringify({
          "@context": "https://schema.org",
          "@type": "Organization",
          "name": "VGG Design & Dev",
          "url": site.url,
          "description": description,
          "founder": {
            "@type": "Person",
            "name": "Francisco Victorico Aguirre Jiménez"
          },
          "sameAs": [
            "https://github.com/Francisco-0510",
            "https://www.linkedin.com/in/vicwith-gg/",
            "https://x.com/VicWithGG1",
            "https://www.figma.com/@vicwithgg"
          ]
        })}
      </script>
    )}

    <slot name="head" />

    <!-- Preload critical fonts -->
    <link
      rel="preload"
      href="/fonts/barlow-condensed-900.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/barlow-condensed-700.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/ibm-plex-mono-400.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <style>
      @font-face {
        font-family: 'Barlow Condensed';
        src: url('/fonts/barlow-condensed-900.woff2') format('woff2');
        font-weight: 900;
        font-display: swap;
      }
      @font-face {
        font-family: 'Barlow Condensed';
        src: url('/fonts/barlow-condensed-700.woff2') format('woff2');
        font-weight: 700;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'IBM Plex Mono';
        src: url('/fonts/ibm-plex-mono-400.woff2') format('woff2');
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }
    </style>
  </head>

  <body>
    <a href="#main-content" class="skip-link">SALTAR AL CONTENIDO</a>

    <main id="main-content" tabindex="-1">
      <slot />
    </main>

    <script>
      function initPage() {
        // ── Reveal on scroll ──────────────────────────────────────
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                (entry.target as HTMLElement).classList.add('visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.08, rootMargin: '0px 0px -60px 0px' },
        );
        document
          .querySelectorAll<HTMLElement>('.reveal:not(.visible)')
          .forEach((el) => observer.observe(el));

        // ── Navbar scroll class ───────────────────────────────────
        const navbar = document.getElementById('navbar');
        if (navbar) {
          let ticking = false;
          const onScroll = () => {
            if (!ticking) {
              requestAnimationFrame(() => {
                navbar.classList.toggle('scrolled', window.scrollY > 50);
                ticking = false;
              });
              ticking = true;
            }
          };
          window.addEventListener('scroll', onScroll, { passive: true });
          onScroll();
        }

        // ── Smooth scroll anchors ─────────────────────────────────
        document
          .querySelectorAll<HTMLAnchorElement>('a[href^="#"]')
          .forEach((anchor) => {
            anchor.addEventListener('click', (e) => {
              const href = anchor.getAttribute('href');
              if (!href || href === '#') return;
              e.preventDefault();
              const target = document.getElementById(href.slice(1));
              if (target) {
                target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                history.pushState(null, '', href);
              }
            });
          });

        // ── Copy code blocks ──────────────────────────────────────
        document.querySelectorAll('pre').forEach((pre) => {
          if (pre.querySelector('.copy-btn')) return;
          const btn = document.createElement('button');
          btn.className = 'copy-btn';
          btn.setAttribute('aria-label', 'Copiar código');
          btn.setAttribute('title', 'Copiar al portapapeles');
          btn.textContent = 'Copiar';
          btn.addEventListener('click', async () => {
            const code = pre.querySelector('code')?.textContent ?? '';
            try {
              await navigator.clipboard.writeText(code);
              btn.textContent = '¡Copiado!';
              btn.classList.add('copied');
              setTimeout(() => {
                btn.textContent = 'Copiar';
                btn.classList.remove('copied');
              }, 2000);
            } catch {
              btn.textContent = 'Error';
            }
          });
          pre.style.position = 'relative';
          pre.appendChild(btn);
        });
      }

      initPage();
      document.addEventListener('astro:page-load', initPage);
    </script>

    <slot name="scripts" />
    <Analytics />
    <SpeedInsights />
  </body>
</html>

<style is:global>
  /* Skip link */
  .skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    z-index: 999;
    padding: 0.5rem 1rem;
    background: var(--color-bg);
    color: var(--color-fg);
    font-weight: 700;
    border: 2px solid currentColor;
    border-radius: 4px;
    transition: top 0.1s;
  }
  .skip-link:focus {
    top: 1rem;
  }

  /* Evita focus ring visible en main al usar skip-link */
  #main-content:focus {
    outline: none;
  }

  /* Copy button */
  .copy-btn {
    position: absolute;
    top: 12px;
    right: 12px;
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 4px 10px;
    background: rgba(217, 168, 78, 0.12);
    border: 1px solid rgba(217, 168, 78, 0.3);
    color: var(--accent);
    cursor: pointer;
    border-radius: 3px;
    transition:
      background 0.2s,
      border-color 0.2s,
      color 0.2s;
    line-height: 1.6;
  }
  .copy-btn:hover {
    background: rgba(217, 168, 78, 0.22);
    border-color: var(--accent);
  }
  .copy-btn.copied {
    background: rgba(26, 188, 132, 0.15);
    border-color: rgba(26, 188, 132, 0.5);
    color: #1abc84;
  }
  .copy-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
</style>
