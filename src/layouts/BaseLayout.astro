---
// src/layouts/BaseLayout.astro
import '../styles/global.css';
import { getSameAs, person, site } from '../data/portfolio';
import ClientRouter from 'astro/components/ClientRouter.astro';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  keywords?: string[];
  publishedDate?: string; // ISO 8601, solo para case studies
  //modifiedDate?: string;
}

const {
  title = `${site.title} | Diseñador UX/UI y Desarrollador Frontend en México`,
  description = 'Diseñador UX/UI y Desarrollador Frontend en México especializado en crear experiencias digitales modernas, accesibles y optimizadas para rendimiento y conversión.',
  ogImage = '/og-image.jpg',
  ogType = 'website',
  keywords = [],
  publishedDate,
  //modifiedDate,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, site.url);
const ogImageURL = new URL(ogImage, site.url).toString();

// Keywords base + especificas
const defaultKeywords = [
  'Diseñador UX/UI en México',
  'Desarrollador Frontend México',
  'Diseño web profesional',
  'Portafolio UX UI',
  'Desarrollador web Oaxaca',
  'Experiencia de usuario diseño',
  'Frontend developer portfolio',
];
const allKeywords = [...new Set([...defaultKeywords, ...keywords])].join(', ');

// JSON-LD: Person + WebSite en la homepage, WebPage en subpáginas
const isHome = Astro.url.pathname === '/';

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: person.name,
  alternateName: person.handle,
  url: site.url,
  image: new URL(person.photo, site.url).toString(),
  jobTitle: person.roles.join(' y '),
  email: person.email,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Oaxaca de Juárez',
    addressRegion: 'Oaxaca',
    addressCountry: 'MX',
  },
  sameAs: getSameAs(), // ← automático desde portfolio.ts
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: site.title,
  url: site.url,
  author: { '@type': 'Person', name: 'Francisco Victorico Aguirre Jiménez' },
  inLanguage: 'es-MX',
  potentialAction: {
    '@type': 'SearchAction',
    target: `${site.url}/?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};
// Para case studies (artículos/proyectos)
const articleSchema =
  !isHome && publishedDate
    ? {
        '@context': 'https://schema.org',
        '@type': 'Article',
        headline: title,
        description,
        image: ogImageURL,
        author: {
          '@type': 'Person',
          name: 'Francisco Victorico Aguirre Jiménez',
          url: site.url,
        },
        publisher: {
          '@type': 'Person',
          name: 'Francisco Victorico Aguirre Jiménez',
          url: site.url,
        },
        datePublished: publishedDate,
        url: canonicalURL.toString(),
        mainEntityOfPage: canonicalURL.toString(),
      }
    : null;
---

<!doctype html>
<html lang={site.locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#06080d" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="generator" content={Astro.generator} />
    <meta name="author" content="Francisco Victorico Aguirre Jiménez" />
    <meta name="keywords" content={allKeywords} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Sitemap autodiscovery -->
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${title} — VicWithGG Portfolio`} />
    <meta property="og:locale" content="es_MX" />
    <meta property="og:site_name" content="VicWithGG" />
    {
      publishedDate && (
        <meta property="article:published_time" content={publishedDate} />
      )
    }

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content={`${title} — VicWithGG Portfolio`} />
    {site.twitter && <meta name="twitter:creator" content={site.twitter} />}
    {site.twitter && <meta name="twitter:site" content={site.twitter} />}

    <!-- JSON-LD Structured Data -->
    {
      isHome && (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(personSchema)}
        />
      )
    }
    {
      isHome && (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(websiteSchema)}
        />
      )
    }
    {
      articleSchema && (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(articleSchema)}
        />
      )
    }

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${site.title} — RSS`}
      href="/rss.xml"
    />
    <link rel="preconnect" href="https://va.vercel-scripts.com" crossorigin />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-06Y0L16P02"
    ></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());

      gtag('config', 'G-06Y0L16P02');
    </script>
  </head>
  <!-- Google tag (gtag.js) -->

  <ClientRouter />

  <slot name="head" />
  <!-- Preload solo fonts del above-the-fold (hero) -->
  <link
    rel="preload"
    href="/fonts/barlow-condensed-900.woff2"
    as="font"
    type="font/woff2"
    crossorigin
  />

  <link
    rel="preload"
    href="/fonts/barlow-condensed-700.woff2"
    as="font"
    type="font/woff2"
    crossorigin
  />
  <link
    rel="preload"
    href="/fonts/ibm-plex-mono-400.woff2"
    as="font"
    type="font/woff2"
    crossorigin
  />

  <style>
    @font-face {
      font-family: 'Barlow Condensed';
      src: url('/fonts/barlow-condensed-900.woff2') format('woff2');
      font-weight: 900;
      font-display: swap;
    }
    @font-face {
      font-family: 'Barlow Condensed';
      src: url('/fonts/barlow-condensed-700.woff2') format('woff2');
      font-weight: 700;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: 'IBM Plex Mono';
      src: url('/fonts/ibm-plex-mono-400.woff2') format('woff2');
      font-weight: 400;
      font-style: normal;
      font-display: swap;
    }
  </style>

  <body>
    <a href="#main-content" class="skip-link">SALTAR AL CONTENIDO</a>

    <main id="main-content" tabindex="-1">
      <slot />
    </main>

    <script>
      function initPage() {
        // ── Reveal on scroll ──────────────────────────────────────
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                (entry.target as HTMLElement).classList.add('visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.08, rootMargin: '0px 0px -60px 0px' },
        );
        document
          .querySelectorAll<HTMLElement>('.reveal:not(.visible)')
          .forEach((el) => observer.observe(el));

        // ── Navbar scroll class ───────────────────────────────────
        const navbar = document.getElementById('navbar');
        if (navbar) {
          let ticking = false;
          const onScroll = () => {
            if (!ticking) {
              requestAnimationFrame(() => {
                navbar.classList.toggle('scrolled', window.scrollY > 50);
                ticking = false;
              });
              ticking = true;
            }
          };
          window.addEventListener('scroll', onScroll, { passive: true });
          onScroll();
        }

        // ── Smooth scroll anchors ─────────────────────────────────
        document
          .querySelectorAll<HTMLAnchorElement>('a[href^="#"]')
          .forEach((anchor) => {
            anchor.addEventListener('click', (e) => {
              const href = anchor.getAttribute('href');
              if (!href || href === '#') return;
              e.preventDefault();
              const target = document.getElementById(href.slice(1));
              if (target) {
                target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                history.pushState(null, '', href);
              }
            });
          });

        // ── Copy code blocks ──────────────────────────────────────
        document.querySelectorAll('pre').forEach((pre) => {
          if (pre.querySelector('.copy-btn')) return;
          const btn = document.createElement('button');
          btn.className = 'copy-btn';
          btn.setAttribute('aria-label', 'Copiar código');
          btn.setAttribute('title', 'Copiar al portapapeles');
          btn.textContent = 'Copiar';
          btn.addEventListener('click', async () => {
            const code = pre.querySelector('code')?.textContent ?? '';
            try {
              await navigator.clipboard.writeText(code);
              btn.textContent = '¡Copiado!';
              btn.classList.add('copied');
              setTimeout(() => {
                btn.textContent = 'Copiar';
                btn.classList.remove('copied');
              }, 2000);
            } catch {
              btn.textContent = 'Error';
            }
          });
          pre.style.position = 'relative';
          pre.appendChild(btn);
        });
      }

      initPage();
      document.addEventListener('astro:page-load', initPage);
    </script>

    <slot name="scripts" />
    <Analytics />
    <SpeedInsights />
  </body>

  <style is:global>
    /* Skip link */
    .skip-link {
      position: absolute;
      top: -100%;
      left: 1rem;
      z-index: 999;
      padding: 0.5rem 1rem;
      background: var(--color-bg);
      color: var(--color-fg);
      font-weight: 700;
      border: 2px solid currentColor;
      border-radius: 4px;
      transition: top 0.1s;
    }
    .skip-link:focus {
      top: 1rem;
    }

    /* Evita focus ring visible en main al usar skip-link */
    #main-content:focus {
      outline: none;
    }

    /* Fallback font metrics — elimina CLS en Barlow Condensed */

    /* Copy button */
    .copy-btn {
      position: absolute;
      top: 12px;
      right: 12px;
      font-family: var(--f-mono);
      font-size: 10px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 4px 10px;
      background: rgba(217, 168, 78, 0.12);
      border: 1px solid rgba(217, 168, 78, 0.3);
      color: var(--accent);
      cursor: pointer;
      border-radius: 3px;
      transition:
        background 0.2s,
        border-color 0.2s,
        color 0.2s;
      line-height: 1.6;
    }
    .copy-btn:hover {
      background: rgba(217, 168, 78, 0.22);
      border-color: var(--accent);
    }
    .copy-btn.copied {
      background: rgba(26, 188, 132, 0.15);
      border-color: rgba(26, 188, 132, 0.5);
      color: #1abc84;
    }
    .copy-btn:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }
  </style>
</html>
