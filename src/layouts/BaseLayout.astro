---
// src/layouts/BaseLayout.astro
import '../styles/global.css';
import { site } from '../data/portfolio';
import ClientRouter from 'astro/components/ClientRouter.astro';
import Analytics from '@vercel/analytics/astro';
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = site.title,
  description = site.description,
  ogImage = '/og-image.jpg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, site.url);
---

<!doctype html>
<html lang={site.locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#06080d" />
    <meta name="robots" content="index, follow" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>

    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, site.url)} />
    <meta property="og:locale" content="es_MX" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, site.url)} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />

    <!-- RSS autodiscovery -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${site.title} — RSS`}
      href="/rss.xml"
    />
    <link rel="dns-prefetch" href="https://va.vercel-scripts.com" />
    <!--
      FONTS SELF-HOSTED
      Coloca los woff2 en public/fonts/ con nombres fijos (sin hashes):
        public/fonts/barlow-condensed-900.woff2
        public/fonts/barlow-condensed-700.woff2
        public/fonts/lora-400.woff2
        public/fonts/ibm-plex-mono-400.woff2

      Descarga desde: https://google-webfonts-helper.herokuapp.com/
      O con fontsource: npm install @fontsource/barlow-condensed
    -->

    <!-- Preload solo fonts del above-the-fold (hero) -->
    <link
      rel="preload"
      href="/fonts/barlow-condensed-900.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/lora-400.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- Astro View Transitions -->
    <ClientRouter />

    <slot name="head" />
  </head>

  <body>
    <a href="#main-content" class="skip-link">SALTAR AL CONTENIDO</a>

    <main id="main-content" tabindex="-1">
      <slot />
    </main>

    <!-- Analytics al final del body, nunca en el head -->
    <!--    <script>
      import('@vercel/analytics').then(({ inject }) => inject());
    </script> -->

    <script>
      function initPage() {
        // ── Reveal on scroll ──────────────────────────────────────
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                (entry.target as HTMLElement).classList.add('visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.08, rootMargin: '0px 0px -60px 0px' },
        );
        document
          .querySelectorAll<HTMLElement>('.reveal:not(.visible)')
          .forEach((el) => observer.observe(el));

        // ── Navbar scroll class ───────────────────────────────────
        const navbar = document.getElementById('navbar');
        if (navbar) {
          let ticking = false;
          const onScroll = () => {
            if (!ticking) {
              requestAnimationFrame(() => {
                navbar.classList.toggle('scrolled', window.scrollY > 50);
                ticking = false;
              });
              ticking = true;
            }
          };
          window.addEventListener('scroll', onScroll, { passive: true });
          onScroll();
        }

        // ── Smooth scroll anchors ─────────────────────────────────
        document
          .querySelectorAll<HTMLAnchorElement>('a[href^="#"]')
          .forEach((anchor) => {
            anchor.addEventListener('click', (e) => {
              const href = anchor.getAttribute('href');
              if (!href || href === '#') return;
              e.preventDefault();
              const target = document.getElementById(href.slice(1));
              if (target) {
                target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                history.pushState(null, '', href);
              }
            });
          });

        // ── Copy code blocks ──────────────────────────────────────
        document.querySelectorAll('pre').forEach((pre) => {
          if (pre.querySelector('.copy-btn')) return;
          const btn = document.createElement('button');
          btn.className = 'copy-btn';
          btn.setAttribute('aria-label', 'Copiar código');
          btn.setAttribute('title', 'Copiar al portapapeles');
          btn.textContent = 'Copiar';
          btn.addEventListener('click', async () => {
            const code = pre.querySelector('code')?.textContent ?? '';
            try {
              await navigator.clipboard.writeText(code);
              btn.textContent = '¡Copiado!';
              btn.classList.add('copied');
              setTimeout(() => {
                btn.textContent = 'Copiar';
                btn.classList.remove('copied');
              }, 2000);
            } catch {
              btn.textContent = 'Error';
            }
          });
          pre.style.position = 'relative';
          pre.appendChild(btn);
        });
      }

      initPage();
      document.addEventListener('astro:page-load', initPage);
    </script>

    <slot name="scripts" />
    <Analytics />
  </body>
</html>

<style is:global>
  /* Skip link */
  .skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    z-index: 999;
    padding: 0.5rem 1rem;
    background: var(--color-bg);
    color: var(--color-fg);
    font-weight: 700;
    border: 2px solid currentColor;
    border-radius: 4px;
    transition: top 0.1s;
  }
  .skip-link:focus {
    top: 1rem;
  }

  /* Evita focus ring visible en main al usar skip-link */
  #main-content:focus {
    outline: none;
  }

  /* Fallback font metrics — elimina CLS en Barlow Condensed */
  @font-face {
    font-family: 'Barlow Condensed Fallback';
    src: local('Arial Narrow'), local('Arial');
    size-adjust: 97%;
    ascent-override: 90%;
    descent-override: 22%;
    line-gap-override: 0%;
    font-display: swap;
  }

  /* Fallback font metrics — elimina CLS en Lora */
  @font-face {
    font-family: 'Lora Fallback';
    src: local('Georgia'), local('Times New Roman');
    size-adjust: 103%;
    ascent-override: 88%;
    descent-override: 24%;
    line-gap-override: 0%;
    font-display: swap;
  }

  /* Copy button */
  .copy-btn {
    position: absolute;
    top: 12px;
    right: 12px;
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 4px 10px;
    background: rgba(217, 168, 78, 0.12);
    border: 1px solid rgba(217, 168, 78, 0.3);
    color: var(--accent);
    cursor: pointer;
    border-radius: 3px;
    transition:
      background 0.2s,
      border-color 0.2s,
      color 0.2s;
    line-height: 1.6;
  }
  .copy-btn:hover {
    background: rgba(217, 168, 78, 0.22);
    border-color: var(--accent);
  }
  .copy-btn.copied {
    background: rgba(26, 188, 132, 0.15);
    border-color: rgba(26, 188, 132, 0.5);
    color: #1abc84;
  }
  .copy-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
</style>
