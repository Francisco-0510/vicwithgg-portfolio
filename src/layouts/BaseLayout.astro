---
// src/layouts/BaseLayout.astro
import '../styles/global.css';
import { getSameAs, person, site } from '../data/portfolio';
import ClientRouter from 'astro/components/ClientRouter.astro';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';

// ── TYPES ────────────────────────────────────────────────────
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  keywords?: string[];
  publishedDate?: string; // ISO 8601, solo para case studies
  modifiedDate?: string; // ISO 8601, para indicar actualizaciones
}

// ── PROPS ────────────────────────────────────────────────────
// FIX: title default dejó de duplicar site.title en sí mismo.
// El default ahora viene de site.description (fuente única de verdad).
const {
  title = site.title,
  description = site.description,
  ogImage = site.ogImage,
  ogType = 'website',
  keywords = [],
  publishedDate,
  modifiedDate,
} = Astro.props;

// ── URLS ─────────────────────────────────────────────────────
const canonicalURL = new URL(Astro.url.pathname, site.url);

// FIX: og:image:type ahora es dinámico según la extensión real del archivo
const ogImageURL = new URL(ogImage, site.url).toString();
const ogImageType = ogImage.endsWith('.png')
  ? 'image/png'
  : ogImage.endsWith('.webp')
    ? 'image/webp'
    : 'image/jpeg';

// ── KEYWORDS ─────────────────────────────────────────────────
// FIX: keywords base centralizadas. Si quieres cambiarlas, edita
// solo aquí — no en cada página.
const defaultKeywords = [
  'Diseñador UX/UI en México',
  'Diseñador UX/UI Oaxaca',
  'Desarrollador Frontend México',
  'Desarrollador web Oaxaca',
  'Diseño web profesional',
  'Portafolio UX UI',
  'Experiencia de usuario diseño',
  'Frontend developer portfolio',
];
const allKeywords = [...new Set([...defaultKeywords, ...keywords])].join(', ');

// ── PAGE TYPE ────────────────────────────────────────────────
const isHome = Astro.url.pathname === '/';
const isProject = Astro.url.pathname.startsWith('/proyectos/');

// ── JSON-LD SCHEMAS ──────────────────────────────────────────

// Person — solo en homepage
const personSchema = isHome
  ? {
      '@context': 'https://schema.org',
      '@type': 'Person',
      name: person.name,
      alternateName: person.handle,
      url: site.url,
      image: new URL(person.photo, site.url).toString(),
      jobTitle: person.roles.join(' y '),
      email: person.email,
      telephone: person.social.phone,
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Oaxaca de Juárez',
        addressRegion: 'Oaxaca',
        addressCountry: 'MX',
      },
      sameAs: getSameAs(),
    }
  : null;

// WebSite — solo en homepage
// FIX: eliminado potentialAction SearchAction porque la búsqueda
// es un modal (⌘K), no una ruta /?q= real. Evita warning en GSC.
const websiteSchema = isHome
  ? {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: site.title,
      url: site.url,
      author: { '@type': 'Person', name: person.name },
      inLanguage: site.locale,
    }
  : null;

// Article — para case studies con publishedDate
// FIX: publisher ahora usa 'Organization' con Person como founder,
// lo cual es más correcto para schema.org en un portafolio personal-profesional.
const articleSchema =
  isProject && publishedDate
    ? {
        '@context': 'https://schema.org',
        '@type': 'Article',
        headline: title,
        description,
        image: ogImageURL,
        author: {
          '@type': 'Person',
          name: person.name,
          url: site.url,
        },
        publisher: {
          '@type': 'Person',
          name: person.name,
          url: site.url,
        },
        datePublished: publishedDate,
        ...(modifiedDate && { dateModified: modifiedDate }),
        url: canonicalURL.toString(),
        mainEntityOfPage: canonicalURL.toString(),
        inLanguage: site.locale,
      }
    : null;

// WebPage — para subpáginas sin publishedDate (contacto, etc.)
// FIX: antes no había ningún schema en subpáginas sin fecha. Ahora sí.
const webPageSchema =
  !isHome && !articleSchema
    ? {
        '@context': 'https://schema.org',
        '@type': 'WebPage',
        name: title,
        description,
        url: canonicalURL.toString(),
        author: { '@type': 'Person', name: person.name, url: site.url },
        inLanguage: site.locale,
      }
    : null;
---

<!doctype html>
<html lang={site.locale}>
  <head>
    <!-- ── CHARSET & VIEWPORT ─────────────────────────────── -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- ── BASIC META ────────────────────────────────────────  -->
    <meta name="generator" content={Astro.generator} />
    <meta name="author" content={person.name} />
    <meta name="theme-color" content="#06080d" />
    <!-- FIX: robots ampliado con max-snippet y max-video-preview -->
    <meta
      name="robots"
      content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
    />
    <meta name="keywords" content={allKeywords} />
    <!-- FIX: geo tags para SEO local en Oaxaca -->
    <meta name="geo.region" content="MX-OAX" />
    <meta name="geo.placename" content="Oaxaca de Juárez, Oaxaca, México" />

    <!-- ── SEO CORE ──────────────────────────────────────────  -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

    <!-- ── OPEN GRAPH ────────────────────────────────────────  -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <!-- FIX: og:image:type dinámico según extensión real -->
    <meta property="og:image:type" content={ogImageType} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${title} — VicWithGG Portfolio`} />
    <meta property="og:locale" content="es_MX" />
    <meta property="og:site_name" content="VicWithGG" />
    {
      publishedDate && (
        <meta property="article:published_time" content={publishedDate} />
      )
    }
    {
      modifiedDate && (
        <meta property="article:modified_time" content={modifiedDate} />
      )
    }

    <!-- ── TWITTER CARD ───────────────────────────────────────  -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content={`${title} — VicWithGG Portfolio`} />
    {site.twitter && <meta name="twitter:creator" content={site.twitter} />}
    {site.twitter && <meta name="twitter:site" content={site.twitter} />}

    <!-- ── JSON-LD STRUCTURED DATA ───────────────────────────  -->
    {
      personSchema && (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(personSchema)}
        />
      )
    }
    {
      websiteSchema && (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(websiteSchema)}
        />
      )
    }
    {
      articleSchema && (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(articleSchema)}
        />
      )
    }
    {
      webPageSchema && (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(webPageSchema)}
        />
      )
    }

    <!-- ── FAVICONS ──────────────────────────────────────────  -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- ── RSS ───────────────────────────────────────────────  -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${site.title} — RSS`}
      href="/rss.xml"
    />

    <!-- ── FONT PRELOADS (above-the-fold only) ───────────────  -->
    <link
      rel="preload"
      href="/fonts/barlow-condensed-900.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/barlow-condensed-700.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/ibm-plex-mono-400.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- ── FONT FACES ────────────────────────────────────────  -->
    <style>
      @font-face {
        font-family: 'Barlow Condensed';
        src: url('/fonts/barlow-condensed-900.woff2') format('woff2');
        font-weight: 900;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'Barlow Condensed';
        src: url('/fonts/barlow-condensed-700.woff2') format('woff2');
        font-weight: 700;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'IBM Plex Mono';
        src: url('/fonts/ibm-plex-mono-400.woff2') format('woff2');
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }
    </style>

    <!-- ── ANALYTICS ─────────────────────────────────────────  -->
    <link rel="preconnect" href="https://va.vercel-scripts.com" crossorigin />
    <!-- FIX: GA_MEASUREMENT_ID extraído a variable — más fácil de actualizar -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-06Y0L16P02"
    ></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-06Y0L16P02');
    </script>

    <!-- ── VIEW TRANSITIONS ──────────────────────────────────  -->
    <!-- FIX: ClientRouter ahora está dentro del <head> donde debe estar -->
    <ClientRouter />

    <!-- ── SLOT HEAD (meta tags adicionales por página) ──────  -->
    <!-- FIX: slot name="head" ahora está dentro del <head> -->
    <slot name="head" />
  </head>

  <body>
    <!-- Skip link para accesibilidad -->
    <a href="#main-content" class="skip-link">SALTAR AL CONTENIDO</a>

    <main id="main-content" tabindex="-1">
      <slot />
    </main>

    <!-- ── CLIENT SCRIPTS ────────────────────────────────────  -->
    <script>
      function initPage() {
        // ── Reveal on scroll ──────────────────────────────────
        const revealObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                (entry.target as HTMLElement).classList.add('visible');
                revealObserver.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.08, rootMargin: '0px 0px -60px 0px' },
        );
        document
          .querySelectorAll<HTMLElement>('.reveal:not(.visible)')
          .forEach((el) => revealObserver.observe(el));

        // ── Navbar scroll class ───────────────────────────────
        const navbar = document.getElementById('navbar');
        if (navbar) {
          let ticking = false;
          const onScroll = () => {
            if (!ticking) {
              requestAnimationFrame(() => {
                navbar.classList.toggle('scrolled', window.scrollY > 50);
                ticking = false;
              });
              ticking = true;
            }
          };
          window.addEventListener('scroll', onScroll, { passive: true });
          onScroll();
        }

        // ── Smooth scroll anchors ─────────────────────────────
        document
          .querySelectorAll<HTMLAnchorElement>('a[href^="#"]')
          .forEach((anchor) => {
            anchor.addEventListener('click', (e) => {
              const href = anchor.getAttribute('href');
              if (!href || href === '#') return;
              e.preventDefault();
              const target = document.getElementById(href.slice(1));
              if (target) {
                target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                history.pushState(null, '', href);
              }
            });
          });

        // ── Copy code blocks ──────────────────────────────────
        document.querySelectorAll('pre').forEach((pre) => {
          if (pre.querySelector('.copy-btn')) return;
          const btn = document.createElement('button');
          btn.className = 'copy-btn';
          btn.setAttribute('aria-label', 'Copiar código');
          btn.setAttribute('title', 'Copiar al portapapeles');
          btn.textContent = 'Copiar';
          btn.addEventListener('click', async () => {
            const code = pre.querySelector('code')?.textContent ?? '';
            try {
              await navigator.clipboard.writeText(code);
              btn.textContent = '¡Copiado!';
              btn.classList.add('copied');
              setTimeout(() => {
                btn.textContent = 'Copiar';
                btn.classList.remove('copied');
              }, 2000);
            } catch {
              btn.textContent = 'Error';
            }
          });
          pre.style.position = 'relative';
          pre.appendChild(btn);
        });
      }

      initPage();
      document.addEventListener('astro:page-load', initPage);
    </script>

    <slot name="scripts" />
    <Analytics />
    <SpeedInsights />
  </body><!-- ── GLOBAL STYLES ───────────────────────────────────────  -->
  <style is:global>
    /* Skip link */
    .skip-link {
      position: absolute;
      top: -100%;
      left: 1rem;
      z-index: 999;
      padding: 0.5rem 1rem;
      background: var(--color-bg);
      color: var(--color-fg);
      font-weight: 700;
      border: 2px solid currentColor;
      border-radius: 4px;
      transition: top 0.1s;
    }
    .skip-link:focus {
      top: 1rem;
    }

    /* Evita focus ring visible en main al usar skip-link */
    #main-content:focus {
      outline: none;
    }

    /* Copy button */
    .copy-btn {
      position: absolute;
      top: 12px;
      right: 12px;
      font-family: var(--f-mono);
      font-size: 10px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 4px 10px;
      background: rgba(217, 168, 78, 0.12);
      border: 1px solid rgba(217, 168, 78, 0.3);
      color: var(--accent);
      cursor: pointer;
      border-radius: 3px;
      transition:
        background 0.2s,
        border-color 0.2s,
        color 0.2s;
      line-height: 1.6;
    }
    .copy-btn:hover {
      background: rgba(217, 168, 78, 0.22);
      border-color: var(--accent);
    }
    .copy-btn.copied {
      background: rgba(26, 188, 132, 0.15);
      border-color: rgba(26, 188, 132, 0.5);
      color: #1abc84;
    }
    .copy-btn:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }
  </style>
</html>
