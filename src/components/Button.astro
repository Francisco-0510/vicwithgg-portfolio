---
interface Props {
  link: string;
  text?: string;
  class?: string;
}

const { link, text, class: className } = Astro.props;
---

<a
  href={link}
  class:list={[
    'inline-flex items-center justify-center w-auto px-8 py-3 text-sm md:text-base font-semibold transition-all duration-300 ease-out border rounded-lg',
    'bg-neutral-900 text-white border-neutral-900 hover:bg-white hover:text-neutral-900',
    'dark:bg-white dark:text-neutral-900 dark:border-white dark:hover:bg-transparent dark:hover:text-white dark:hover:border-neutral-300',
    className,
  ]}>
  {text ? text : <slot />}
</a>
