---
interface Props {
  href: string;
  class?: string;
}

const { href, class: className } = Astro.props;
---

<a
  href={href}
  class:list={[
    'not-prose group relative flex w-fit items-center flex-nowrap rounded-lg border border-neutral-200 py-1.5 pl-8 pr-4 text-sm font-medium transition-colors duration-300 ease-out',
    'hover:bg-neutral-100 hover:text-neutral-900 focus-visible:bg-neutral-100 focus-visible:text-neutral-900',
    'dark:border-neutral-800 dark:text-neutral-300 dark:hover:bg-neutral-800 dark:hover:text-white dark:focus-visible:bg-neutral-800 dark:focus-visible:text-white',
    className,
  ]}>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    class="absolute left-2.5 top-1/2 h-4 w-4 -translate-y-1/2 fill-none stroke-current stroke-2">
    <line
      x1="5"
      y1="12"
      x2="19"
      y2="12"
      class="translate-x-2 scale-x-0 transition-transform duration-300 ease-out group-hover:translate-x-0 group-hover:scale-x-100 group-focus-visible:translate-x-0 group-focus-visible:scale-x-100"
    ></line>
    <polyline
      points="12 5 5 12 12 19"
      class="translate-x-1 transition-transform duration-300 ease-out group-hover:translate-x-0 group-focus-visible:translate-x-0"
    ></polyline>
  </svg>
  <span>
    <slot />
  </span>
</a>
