---
import projects from '@collections/projects.json';
import { Image } from 'astro:assets';
---

{
  projects.map(({ name, description, highlights, image, link }) => {
    return (
      <article class="relative group">
        <a
          href={link || '#'}
          target="_blank"
          rel="noopener noreferrer"
          class="flex flex-col items-stretch h-full p-3 transition-all duration-300 ease-out border rounded-xl border-neutral-300 dark:border-slate-700/50 hover:border-blue-500/50 hover:shadow-md group-hover:-translate-y-1">
          {/* Contenedor de Imagen */}
          <span class="block w-full overflow-hidden rounded-lg aspect-video bg-neutral-100 dark:bg-neutral-800">
            {image ? (
              <Image
                src={image}
                alt={name}
                width={600}
                height={337}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
            ) : (
              <div class="flex items-center justify-center h-full text-neutral-400 text-xs">
                Sin imagen
              </div>
            )}
          </span>

          {/* Contenido */}
          <span class="flex flex-col flex-grow mt-4">
            <span class="flex items-center justify-between mb-1">
              <span class="text-base font-bold tracking-tight text-neutral-900 dark:text-neutral-100">
                {name}
              </span>

              {/* Icono de Flecha Optimizado */}
              <svg
                class="w-4 h-4 transition-all duration-300 transform -rotate-45 opacity-0 group-hover:opacity-100 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 text-blue-500"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2.5">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"
                />
              </svg>
            </span>

            <p class="text-sm text-neutral-600 dark:text-neutral-400 line-clamp-2 mb-4">
              {description}
            </p>

            {/* Badges de Tecnologías */}
            <ul class="flex flex-wrap gap-1.5 mt-auto">
              {/* Verificamos que highlights exista y tenga elementos antes de renderizar la lista */}
              {highlights && highlights.length > 0 && (
                <ul class="flex flex-wrap gap-1.5 mt-auto pt-4">
                  {highlights.map((highlight) => (
                    <li class="text-[10px] uppercase tracking-wider font-bold py-0.5 px-2 rounded bg-neutral-100 dark:bg-white/10 text-neutral-700 dark:text-neutral-300 border border-neutral-200 dark:border-white/5">
                      {highlight}
                    </li>
                  ))}
                </ul>
              )}
            </ul>
          </span>
        </a>
      </article>
    );
  })
}

<style>
  /* Optimizaciones de layout */
  article {
    height: 100%;
  }

  /* Ajustes para móviles */
  @media (max-width: 640px) {
    article {
      border-radius: 0;
    }
  }
</style>
