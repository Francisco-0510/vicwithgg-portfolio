---
interface Props {
  dates: string;
  role: string;
  company: string;
  description: string;
  logo: string;
}

const { dates, role, company, description, logo } = Astro.props;
---

<div
  class="relative mx-12 pb-12 grid before:absolute before:left-[-35px] before:block before:h-full before:border-l-2 before:border-neutral-200 dark:before:border-neutral-800 before:content-[''] md:grid-cols-5 md:gap-10 md:space-x-4">
  <div class="relative pb-4 md:col-span-2 md:pb-0">
    <div class="sticky top-0">
      <span
        class="absolute -left-[50px] top-1 flex h-8 w-8 items-center justify-center rounded-full bg-white dark:bg-neutral-950 ring-2 ring-neutral-200 dark:ring-neutral-800 overflow-hidden p-0.5">
        <img
          src={logo}
          alt={`Logo de ${company}`}
          class="h-full w-full rounded-full object-contain"
          loading="lazy"
          decoding="async"
        />
      </span>

      <h3 class="text-xl font-bold text-neutral-900 dark:text-neutral-100">
        {role}
      </h3>
      <p
        class="font-medium text-sm text-blue-600 dark:text-blue-400 mt-1 text-pretty">
        {company}
      </p>
      <time
        class="mt-2 block text-sm font-medium leading-none text-neutral-500 dark:text-neutral-400">
        {dates}
      </time>
    </div>
  </div>

  <div class="relative flex flex-col gap-2 tracking-normal md:col-span-3">
    <p
      class="text-sm leading-relaxed font-normal text-neutral-700 dark:text-neutral-300 text-pretty">
      {description}
    </p>
  </div>
</div>
