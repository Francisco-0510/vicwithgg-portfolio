---
import projects from '@collections/projects.json';
import Figma from '@components/icons/Figma.astro';
import GitHub from '@components/icons/GitHub.astro';
import PageHeading from '@components/Page-heading.astro';
import { Image } from 'astro:assets';
---

<section
  id="projects"
  class="py-16 space-y-12"
  aria-labelledby="projects-title">
  <div class="space-y-6">
    <PageHeading
      id="projects-title"
      title="Proyectos Destacados"
      description="Una selección de trabajos donde combino el diseño UX/UI con el desarrollo frontend para crear experiencias digitales funcionales."
    />

    <nav
      class="flex gap-6 items-center"
      aria-label="Enlaces a perfiles externos">
      <a
        class="group flex items-center text-sm font-semibold text-blue-600 dark:text-blue-400 focus:outline-none focus:underline"
        href="https://www.figma.com/@vicwithgg"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Explorar mis diseños en Figma (abre en nueva pestaña)">
        Explorar Figma
        <span
          class="ml-1 transition-transform group-hover:translate-x-1"
          aria-hidden="true">&rarr;</span
        >
      </a>
      <a
        class="group flex items-center text-sm font-semibold text-blue-600 dark:text-blue-400 focus:outline-none focus:underline"
        href="https://github.com/Francisco-0510"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Ver mi perfil de GitHub (abre en nueva pestaña)">
        GitHub Perfil
        <span
          class="ml-1 transition-transform group-hover:translate-x-1"
          aria-hidden="true">&rarr;</span
        >
      </a>
    </nav>
  </div>

  <div class="grid w-full gap-8 sm:grid-cols-2 lg:grid-cols-3">
    {
      projects.map(
        (
          { name, description, highlights, image, link, figma, github },
          index,
        ) => (
          <article
            class="group flex flex-col bg-white border border-neutral-200 shadow-sm rounded-2xl overflow-hidden transition-all duration-500 hover:shadow-xl hover:-translate-y-1 dark:bg-neutral-900/40 dark:border-neutral-800/60 dark:hover:bg-neutral-900/60"
            itemscope
            itemtype="http://schema.org/CreativeWork">
            {/* Imagen: Oculta para lectores de pantalla para evitar duplicidad de enlaces */}
            <a
              href={link || '#'}
              target="_blank"
              rel="noopener noreferrer"
              class="block overflow-hidden aspect-video bg-neutral-100 dark:bg-neutral-800"
              tabindex="-1"
              aria-hidden="true">
              {image ? (
                <Image
                  src={image}
                  alt=""
                  width={800}
                  height={450}
                  format="webp"
                  quality="mid"
                  loading={index < 3 ? 'eager' : 'lazy'}
                  class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-110"
                  itemprop="image"
                />
              ) : (
                <div class="w-full h-full flex items-center justify-center">
                  <span class="text-neutral-400 text-xs">
                    Vista previa no disponible
                  </span>
                </div>
              )}
            </a>

            <div class="flex flex-col flex-grow p-6">
              <header class="flex items-start justify-between gap-4">
                <div class="space-y-1">
                  <h3
                    class="text-xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100"
                    itemprop="name">
                    <a
                      href={link || '#'}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 rounded">
                      {name}
                    </a>
                  </h3>
                </div>

                <div class="flex items-center gap-3 pt-1">
                  {github && (
                    <a
                      href={github}
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label={`Ver código fuente de ${name} en GitHub`}
                      class="text-neutral-600 hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-white transition-colors">
                      <GitHub class="w-5 h-5" aria-hidden="true" />
                    </a>
                  )}
                  {figma && (
                    <a
                      href={figma}
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label={`Ver prototipo de ${name} en Figma`}
                      class="text-neutral-600 hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-white transition-colors">
                      <Figma class="w-5 h-5" aria-hidden="true" />
                    </a>
                  )}
                </div>
              </header>

              <p
                class="mt-3 text-sm leading-relaxed text-neutral-600 dark:text-neutral-400 line-clamp-3"
                itemprop="description">
                {description}
              </p>

              <footer class="mt-auto pt-8">
                <div
                  class="flex flex-wrap gap-2"
                  aria-label="Tecnologías utilizadas">
                  {highlights?.map((tag) => (
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-md text-[11px] font-bold tracking-wide uppercase bg-neutral-100 text-neutral-700 border border-neutral-200 dark:bg-neutral-800/50 dark:text-neutral-300 dark:border-neutral-700/50">
                      {tag}
                    </span>
                  ))}
                </div>
              </footer>
            </div>
          </article>
        ),
      )
    }
  </div>
</section>
