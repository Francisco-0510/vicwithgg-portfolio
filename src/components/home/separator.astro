---
// Define los tipos de las Props
interface Props {
  text: string;
  id?: string;
}

const { text, id } = Astro.props;
---

<div class="relative py-16" id={id} role="separator">
  <div class="relative w-full pl-5 overflow-x-hidden md:pl-0">
    {/* Línea con gradiente para ocultar los bordes */}
    <div
      class="absolute w-full h-px bg-gradient-to-r from-transparent to-white md:from-white dark:from-transparent dark:to-neutral-950 md:dark:from-neutral-950 md:via-transparent md:dark:via-transparent md:to-white md:dark:to-neutral-950">
    </div>
    {/* Línea punteada de fondo */}
    <div
      class="w-full h-px border-t border-dashed border-neutral-300 dark:border-neutral-600">
    </div>
  </div>

  {/* Etiqueta flotante con el texto y la flecha */}
  <div
    class="absolute flex items-center justify-center w-auto h-auto px-3 py-1.5 left-0 ml-5 md:left-1/2 md:ml-0 md:-translate-x-1/2 -translate-y-1/2 bg-white dark:bg-neutral-900 border border-neutral-100 dark:border-neutral-800 rounded-full shadow-sm">
    <p
      class="text-[0.6rem] uppercase tracking-widest text-neutral-400 leading-none">
      {text}
    </p>

    <div
      class="flex items-center justify-center w-5 h-5 translate-x-1 border border-neutral-100 dark:border-neutral-800 rounded-full text-neutral-400">
      <svg
        class="w-3 h-3"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="2"
        stroke="currentColor"
        aria-hidden="true">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M12 4.5v15m0 0l6.75-6.75M12 19.5l-6.75-6.75"></path>
      </svg>
    </div>
  </div>
</div>
