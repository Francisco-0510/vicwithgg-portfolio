---
// src/components/sections/Projects.astro
import { getCollection } from 'astro:content';
import Label from '../ui/Label.astro';
import ProjectCard from '../ui/ProjectCard.astro';

const allProjects = await getCollection('proyectos', ({ data }) => !data.draft);

const projects = allProjects.sort((a, b) => {
  if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
  return (a.data.order ?? 99) - (b.data.order ?? 99);
});
---

<section id="projects">
  <div class="wrap">
    <div class="projects-header">
      <div>
        <Label reveal>Descubre mis trabajos</Label>
        <h2 class="projects-h2 reveal reveal-delay-1">
          Algunos de mis Proyectos
        </h2>
      </div>
      <p class="projects-sub reveal reveal-delay-2">
        Diseño y desarrollo de productos digitales para clientes reales, desde
        sistemas de diseño hasta aplicaciones web complejas.
      </p>
    </div>
    <div class="projects-grid" role="list">
      {
        projects.map((project, i) => (
          <div role="listitem">
            <ProjectCard project={project} index={i} />
          </div>
        ))
      }
    </div>
  </div>
</section>
<style>
  #projects {
    padding: 120px 0;
  }
  .projects-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 56px;
    flex-wrap: wrap;
  }
  .projects-h2 {
    font-family: var(--f-display);
    font-size: clamp(38px, 4.5vw, 60px);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    color: var(--text);
    margin: 12px 0 0;
  }
  .projects-sub {
    font-size: 15px;
    color: var(--text-2);
    max-width: 360px;
  }
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    background: var(--line);
  }
  @media (max-width: 900px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
