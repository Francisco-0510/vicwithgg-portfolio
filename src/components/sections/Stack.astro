---
// src/components/sections/Stack.astro
import { stackCategories, techLogos } from '../../data/portfolio';
import Label from '../ui/Label.astro';
import Icon from '../ui/Icon.astro';
import type { IconName } from '../ui/icon-types';
import { Image } from 'astro:assets';

const iconMap: Record<string, IconName> = {
  design: 'design',
  code: 'code',
  data: 'database',
  tools: 'tool',
};
---

<section id="stack">
  <div class="wrap">
    <div class="skills-intro">
      <Label centered reveal>Herramientas y tecnologías</Label>
      <h2 class="stack-h2 reveal reveal-delay-1">Mi Stack</h2>
      <p class="reveal reveal-delay-2">
        Trabajo a lo largo de todo el pipeline de producto — desde la ideación y
        prototipado en Figma hasta el desarrollo e implementación en producción.
      </p>
    </div>
    <div class="skills-grid">
      {
        stackCategories.map((cat, i) => (
          <div class={`skill-category reveal reveal-delay-${i % 3}`}>
            <div class="skill-category-title">
              <Icon name={iconMap[cat.icon] ?? 'tool'} size={18} />
              {cat.title}
            </div>
            <ul class="skill-list" role="list">
              {cat.skills.map((skill) => (
                <li class="skill-item" role="listitem">
                  <Icon name="check" size={14} />
                  {skill}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
    <div class="tech-logos">
      {
        techLogos.map((tech, i) => (
          <div class={`tech-logo-item reveal reveal-delay-${i % 4}`}>
            <Image
              format="webp"
              src={tech.logo}
              alt={tech.name}
              width="40"
              height="40"
              loading="lazy"
              onerror="this.style.opacity='0.2'"
            />
            <span class="tech-logo-name">{tech.name}</span>
            <span class="tech-logo-type">{tech.type}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  #stack {
    padding: 100px 0;
  }
  .skills-intro {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 48px;
  }
  .stack-h2 {
    font-family: var(--f-display);
    font-size: clamp(38px, 4.5vw, 60px);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    color: var(--text);
    margin: 12px 0 16px;
  }
  .skills-intro p {
    font-size: 16px;
    color: var(--text-2);
    line-height: 1.8;
  }
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
    background: var(--line);
    margin-top: 40px;
  }
  @media (max-width: 900px) {
    .skills-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .skill-category {
    background: var(--bg);
    padding: 32px 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .skill-category-title {
    font-family: var(--f-display);
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text);
    padding-bottom: 12px;
    border-bottom: 1px solid var(--line);
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .skill-category-title :global(svg) {
    color: var(--accent);
    flex-shrink: 0;
  }
  .skill-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .skill-item {
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-3);
    display: flex;
    align-items: center;
    gap: 10px;
    transition: color 0.2s;
  }
  .skill-item :global(svg) {
    color: var(--blue);
    flex-shrink: 0;
    transition: color 0.2s;
  }
  .skill-item:hover {
    color: var(--text-2);
  }
  .skill-item:hover :global(svg) {
    color: var(--accent);
  }
  .tech-logos {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 2px;
    background: var(--line);
    margin-top: 40px;
  }
  @media (max-width: 900px) {
    .tech-logos {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .tech-logo-item {
    background: var(--bg);
    padding: 24px 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    text-align: center;
    transition: background 0.3s;
  }
  .tech-logo-item:hover {
    background: var(--bg-card);
  }
  .tech-logo-item img {
    width: 40px;
    height: 40px;
    object-fit: contain;
    filter: grayscale(100%) opacity(0.5);
    transition: filter 0.3s;
  }
  .tech-logo-item:hover img {
    filter: grayscale(0%) opacity(1);
  }
  .tech-logo-name {
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-3);
  }
  .tech-logo-type {
    font-family: var(--f-mono);
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-3);
    opacity: 0.6;
  }
</style>
