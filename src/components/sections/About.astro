---
// src/components/sections/About.astro
import { person, certificates, education } from '../../data/portfolio';
import Label from '../ui/Label.astro';
import Button from '../ui/Button.astro';
import Icon from '../ui/Icon.astro';
import { Image } from 'astro:assets';
---

<section id="about" itemscope itemtype="https://schema.org/Person">
  <div class="wrap">
    <div class="about-inner">
      <!-- Sticky photo column -->
      <div class="about-photo">
        <div class="about-photo-frame">
          <Image
            src={person.photo}
            alt={`Foto de ${person.name}`}
            width="400"
            height="400"
            loading="lazy"
            decoding="async"
            format="webp"
            quality={85}
            itemprop="image"
            onerror="this.style.display='none'"
          />
        </div>

        <div class="about-contact">
          <p>Encuéntrame en</p>
          <div class="about-social">
            {
              person.social.linkedin && (
                <Button
                  href={person.social.linkedin}
                  variant="ghost"
                  target="_blank"
                  aria-label={`${person.name} en LinkedIn`}
                  rel="noopener noreferrer">
                  <Icon slot="icon" name="linkedin" size={14} />
                  LinkedIn
                </Button>
              )
            }
            {
              person.social.github && (
                <Button
                  href={person.social.github}
                  variant="ghost"
                  target="_blank"
                  aria-label={`${person.name} en GitHub`}
                  rel="noopener noreferrer">
                  <Icon slot="icon" name="github" size={14} />
                  GitHub
                </Button>
              )
            }
            {
              person.social.x && (
                <Button
                  href={person.social.x}
                  variant="ghost"
                  target="_blank"
                  aria-label={`${person.name} en Twitter/X`}
                  rel="noopener noreferrer">
                  <Icon slot="icon" name="external-link" size={14} />
                  Twitter
                </Button>
              )
            }
            <Button
              href={`mailto:${person.email}`}
              variant="ghost"
              aria-label={`Enviar email a ${person.name}`}>
              <Icon slot="icon" name="mail" size={14} />
              Email
            </Button>
          </div>
        </div>
      </div>

      <!-- Main content -->
      <div class="about-content">
        <Label reveal>Sobre mí</Label>
        <h2 class="reveal reveal-delay-1">
          Diseñador & Desarrollador<br />
          <em>desde Oaxaca, México</em>
        </h2>

        <!-- Structured Data Meta Tags -->
        <meta itemprop="name" content={person.name} />
        <meta itemprop="jobTitle" content={person.roles.join(', ')} />
        <meta itemprop="email" content={person.email} />
        <meta itemprop="telephone" content={person.social.phone} />
        <meta itemprop="url" content={Astro.site?.toString()} />

        {
          person.bio.map((paragraph, i) => (
            <p class={`reveal reveal-delay-${i + 2}`} itemprop="description">
              {paragraph}
            </p>
          ))
        }

        <!-- Certs & Education -->
        <div class="certs-edu-grid">
          <div class="certs-section">
            <h3 class="reveal">Certificados</h3>
            {
              certificates.map((cert, i) => (
                <div
                  class={`cert-item reveal reveal-delay-${Math.min(i, 5)}`}
                  itemscope
                  itemtype="https://schema.org/EducationalOccupationalCredential">
                  <div class="cert-logo">
                    <Image
                      format="webp"
                      src={cert.logo}
                      alt={cert.org}
                      width="32"
                      height="32"
                      loading="lazy"
                      itemprop="image"
                      onerror="this.style.opacity='0.3'"
                    />
                  </div>
                  <div class="cert-info">
                    <div class="cert-date">
                      <time itemprop="dateSigned">{cert.date}</time>
                    </div>
                    <h4 itemprop="name">{cert.title}</h4>
                    <div class="cert-org" itemprop="issuingOrganization">
                      {cert.org}
                    </div>
                  </div>
                </div>
              ))
            }
          </div>

          <div class="edu-section">
            <h3 class="reveal">Educación</h3>
            {
              education.map((edu, i) => (
                <div
                  class={`edu-item reveal reveal-delay-${Math.min(i, 5)}`}
                  itemscope
                  itemtype="https://schema.org/EducationalOccupationalCredential">
                  <div class="edu-logo">
                    <Image
                      format="webp"
                      src={edu.logo}
                      alt={edu.school}
                      width="32"
                      height="32"
                      loading="lazy"
                      itemprop="image"
                      onerror="this.style.opacity='0.3'"
                    />
                  </div>
                  <div class="edu-info">
                    <div class="edu-date">
                      <time itemprop="dateSigned">{edu.period}</time>
                    </div>
                    <h4 itemprop="name">{edu.degree}</h4>
                    <div class="edu-school" itemprop="issuingOrganization">
                      {edu.school}
                    </div>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Structured Data JSON-LD -->
<script is:inline type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "@id": "https://vicwithgg-portfolio.vercel.app/#about",
    "name": "Francisco Victorico Aguirre Jiménez",
    "alternateName": "VicWithGG",
    "url": "https://vicwithgg-portfolio.vercel.app/",
    "image": "https://vicwithgg-portfolio.vercel.app/images/me.jpg",
    "description": "Diseñador UX/UI y Desarrollador Frontend especializado en React, Astro y Figma con más de 4 años de experiencia.",
    "jobTitle": ["Diseñador UX/UI", "Desarrollador Frontend"],
    "email": "vgg.designer.01@gmail.com",
    "telephone": "+52 1 951 391 5906",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Oaxaca",
      "addressCountry": "MX"
    },
    "sameAs": [
      "https://github.com/Francisco-0510",
      "https://www.linkedin.com/in/vicwith-gg/",
      "https://x.com/VicWithGG1",
      "https://www.figma.com/@vicwithgg",
      "https://www.instagram.com/vicwithgg"
    ],
    "worksFor": {
      "@type": "Organization",
      "name": "VGG Design & Dev",
      "url": "https://vicwithgg-portfolio.vercel.app/"
    }
  }
</script>

<style>
  #about {
    padding: 100px 0;
    background: var(--bg-1);
    border-top: 1px solid var(--line);
  }
  .about-inner {
    display: grid;
    grid-template-columns: 0.4fr 1fr;
    gap: 64px;
    align-items: start;
  }
  @media (max-width: 900px) {
    .about-inner {
      grid-template-columns: 1fr;
      text-align: center;
    }
  }
  .about-photo {
    position: sticky;
    top: 100px;
  }
  .about-photo-frame {
    width: 100%;
    aspect-ratio: 1;
    border: 1px solid var(--line-accent);
    border-radius: 8px;
    overflow: hidden;
    background: var(--bg-card);
  }
  .about-photo-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .about-contact {
    margin-top: 32px;
    padding-top: 24px;
    border-top: 1px solid var(--line);
  }
  .about-contact > p {
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-3);
    margin-bottom: 16px;
  }
  .about-social {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  /* Style ghost buttons in social context as bordered links */
  .about-social :global(.btn--ghost) {
    padding: 10px 16px;
    border: 1px solid var(--line);
    font-size: 10px;
    letter-spacing: 0.1em;
    transition: all 0.2s;
  }
  .about-social :global(.btn--ghost:hover) {
    color: var(--text);
    border-color: var(--accent);
    background: var(--accent-dim);
  }
  .about-content h2 {
    font-family: var(--f-display);
    font-size: 28px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--text);
    margin: 12px 0 24px;
  }
  .about-content h2 em {
    font-style: normal;
    color: var(--accent);
  }
  .about-content > p {
    font-size: 16px;
    color: var(--text-2);
    line-height: 1.8;
    margin-bottom: 24px;
  }
  .certs-edu-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    margin-top: 64px;
  }
  @media (max-width: 900px) {
    .certs-edu-grid {
      grid-template-columns: 1fr;
    }
  }
  .certs-section h3,
  .edu-section h3 {
    font-family: var(--f-display);
    font-size: 22px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--text);
    margin: 0 0 24px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--line);
  }
  .cert-item,
  .edu-item {
    padding: 20px 0;
    border-bottom: 1px solid var(--line);
    display: flex;
    gap: 16px;
  }
  .cert-logo,
  .edu-logo {
    width: 48px;
    height: 48px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-card);
    border: 1px solid var(--line);
    border-radius: 4px;
  }
  .cert-logo img,
  .edu-logo img {
    width: 32px;
    height: 32px;
    object-fit: contain;
    filter: grayscale(100%) opacity(0.6);
  }
  .cert-item:hover .cert-logo img,
  .edu-item:hover .edu-logo img {
    filter: grayscale(0%) opacity(1);
  }
  .cert-date,
  .edu-date {
    font-family: var(--f-mono);
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-3);
    margin-bottom: 4px;
  }
  .cert-info h4,
  .edu-info h4 {
    font-family: var(--f-body);
    font-size: 13px;
    font-weight: 500;
    color: var(--text);
    line-height: 1.4;
    margin-bottom: 4px;
  }
  .cert-org,
  .edu-school {
    font-family: var(--f-mono);
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--blue);
  }
</style>
