---
// src/components/sections/Hero.astro
import { ArrowRight, Download, Mouse } from '@lucide/astro';
import { heroStats, person } from '../../data/portfolio';
import Button from '../ui/Button.astro';
import Card from '../ui/Card.astro';
import Label from '../ui/Label.astro';
---

<section id="hero">
  <div class="grid-bg" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
          <path
            d="M 40 0 L 0 0 0 40"
            fill="none"
            stroke="currentColor"
            stroke-width="1"></path>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid)"></rect>
    </svg>
  </div>
  <div class="hero-lines" aria-hidden="true">
    <svg viewBox="0 0 600 800" fill="none" xmlns="http://www.w3.org/2000/svg">
      <line
        x1="0"
        y1="200"
        x2="600"
        y2="600"
        stroke="currentColor"
        stroke-width="1"></line>
      <line
        x1="100"
        y1="0"
        x2="600"
        y2="400"
        stroke="currentColor"
        stroke-width="1"></line>
      <circle
        cx="300"
        cy="400"
        r="280"
        stroke="currentColor"
        stroke-width="1"
        fill="none"></circle>
      <circle
        cx="450"
        cy="200"
        r="120"
        stroke="currentColor"
        stroke-width="1"
        fill="none"></circle>
    </svg>
  </div>
  <div class="hero-bg-num" aria-hidden="true">01</div>
  <div class="wrap">
    <div class="hero-content">
      <div class="hero-left">
        <Label reveal class="hero-label">Disponible para proyectos</Label>
        <h1 class="hero-h1 reveal reveal-delay-1">
          Diseñador <em>UX/UI</em><br />& Desarrollador
        </h1>
        <p class="hero-desc reveal reveal-delay-2">
          ¡Hola! Soy <strong
            >{person.name.split(' ')[0]} {person.name.split(' ')[1]}</strong
          >. Apasionado Diseñador UX/UI y Desarrollador Web enfocado en crear
          experiencias digitales excepcionales que equilibran las necesidades
          del usuario con los objetivos de negocio.
        </p>
        <div class="hero-actions reveal reveal-delay-3">
          <Button href="/#projects" variant="primary">
            Ver proyectos
            <ArrowRight class="size-3.5" />
            <!-- <Icon slot="icon" name="arrow-right" size={14} /> -->
          </Button>
          <Button
            variant="ghost"
            download={true}
            href="/public/CV_UXUI_Desarrollador-Aguirre_Jimenez_FV.pdf">
            Descargar CV
            <Download class="size-3.5" />
          </Button>
          <!--   <Button href={`mailto:${person.email}`} variant="ghost">
            <Icon slot="icon" name="mail" size={14} />
            {person.email}
          </Button> -->
        </div>
      </div>
      <div class="hero-side">
        {
          heroStats.map((stat, i) => (
            <Card
              variant="stat"
              reveal
              delay={(i + 2) as 0 | 1 | 2 | 3 | 4 | 5}
              padding="none">
              <span slot="num">{stat.num}</span>
              <span slot="label">{stat.label}</span>
            </Card>
          ))
        }
      </div>
    </div>
  </div>
  <div class="hero-scroll" aria-hidden="true">
    <span>Scroll</span>
    <Mouse class="size-4" />
    <!--     <Icon name="scroll" size={16} /> -->
  </div>
</section>

<style>
  #hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 10rem 0;
    overflow: hidden;
  }
  .hero-lines {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 55%;
    pointer-events: none;
    color: var(--text);
    opacity: 0.06;
  }
  .hero-bg-num {
    position: absolute;
    bottom: -40px;
    right: -10px;
    font-family: var(--f-display);
    font-size: clamp(200px, 30vw, 420px);
    font-weight: 900;
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1px rgba(217, 168, 78, 0.06);
    pointer-events: none;
    letter-spacing: -0.02em;
    user-select: none;
  }
  .hero-content {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: flex-end;
    gap: 48px;
  }
  @media (max-width: 900px) {
    .hero-content {
      grid-template-columns: 1fr;
    }
  }
  .hero-label {
    margin-bottom: 24px;
  }
  .hero-h1 {
    font-family: var(--f-display);
    font-size: clamp(62px, 9vw, 128px);
    font-weight: 900;
    line-height: 0.92;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    color: var(--text);
    margin-bottom: 32px;
  }
  .hero-h1 em {
    font-style: normal;
    color: var(--accent);
  }
  .hero-desc {
    font-family: var(--f-body);
    font-size: 17px;
    line-height: 1.75;
    color: var(--text-2);
    max-width: 560px;
    margin-bottom: 48px;
  }
  .hero-desc strong {
    color: var(--text);
    font-weight: 500;
  }
  .hero-actions {
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }
  .hero-side {
    display: flex;
    flex-direction: column;
    gap: 24px;
    padding-bottom: 8px;
    min-width: 200px;
  }
  @media (max-width: 900px) {
    .hero-side {
      flex-direction: row;
      flex-wrap: wrap;
    }
  }
  .hero-scroll {
    position: absolute;
    bottom: 28px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    z-index: 2;
    color: var(--text-3);
    animation: scroll-pulse 2.2s ease-in-out infinite;
  }
  .hero-scroll span {
    font-family: var(--f-mono);
    font-size: 9px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
</style>
