---
import Logo from '../components/logo.astro';
import Moon from './icons/Moon.astro';
import Sun from './icons/sun.astro';

const NAV_LINKS = [
  { label: 'Proyectos', href: '#projects' },
  { label: 'Experiencia', href: '#experience' },
  { label: 'Stack', href: '#stack' },
  { label: 'Sobre mí', href: '#about' },
];
---

<div class="w-full h-20 opacity-0 pointer-events-none"></div>

<header
  id="header"
  class="fixed top-0 z-50 w-full h-20 transition-all duration-300">
  <div
    class="flex items-center justify-between h-full max-w-5xl mx-auto px-6 border-b border-transparent transition-all duration-300 lg:rounded-b-xl">
    <Logo />

    <div
      id="mobileMenuBackground"
      class="fixed inset-0 z-20 hidden w-screen h-screen bg-white/90 dark:bg-neutral-950/90 backdrop-blur-sm opacity-0 transition-opacity duration-300">
    </div>

    <nav
      class="relative z-30 flex items-center justify-end flex-grow text-sm font-medium">
      <button
        id="openMenu"
        aria-label="Abrir menú"
        class="flex items-center justify-center w-10 h-10 sm:hidden text-neutral-600 dark:text-neutral-200">
        <svg
          class="w-8 h-8"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 8h16M4 16h16"></path>
        </svg>
      </button>

      <button
        id="closeMenu"
        aria-label="Cerrar menú"
        class="hidden items-center justify-center w-10 h-10 sm:hidden text-neutral-600 dark:text-neutral-200">
        <svg
          class="w-8 h-8"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>

      <div
        id="menu"
        class="fixed top-[75px] left-0 z-40 hidden w-full pb-8 flex-col items-center bg-white dark:bg-neutral-950 shadow-xl sm:relative sm:top-0 sm:flex sm:flex-row sm:w-auto sm:pb-0 sm:bg-transparent sm:dark:bg-transparent sm:shadow-none">
        {
          NAV_LINKS.map((link) => (
            <a
              href={link.href}
              class="nav-link w-full px-6 py-4 text-center transition-colors duration-200 sm:w-auto sm:py-0 text-neutral-500 hover:text-blue-600 dark:text-neutral-400 dark:hover:text-blue-400">
              {link.label}
            </a>
          ))
        }
      </div>

      <button
        id="darkToggle"
        class="group relative overflow-hidden w-10 h-10 ml-4 rounded-full bg-neutral-200 dark:bg-neutral-700 flex items-center justify-center">
        <div class="horizon flex items-center justify-center">
          <div id="sun" class="absolute transition-all duration-500">
            <Sun class="w-6 h-6" />
          </div>
          <div id="moon" class="absolute transition-all duration-500 hidden">
            <Moon class="w-6 h-6" />
          </div>
        </div>
      </button>
    </nav>
  </div>
</header>

<style>
  /* El diseño del header "glass" se inyecta vía JS al hacer scroll */
  #header.fixed .nav-link {
    @apply sm:py-2;
  }

  /* Evitar saltos visuales en modo móvil */
  @media (max-width: 640px) {
    #menu {
      height: calc(100vh - 75px);
      justify-content: center;
    }
  }
</style>
