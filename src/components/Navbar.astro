---
// Usamos los enlaces refactorizados para mantener la coherencia
import Logo from '../components/logo.astro';
import Sun from './icons/sun.astro';
import Moon from './icons/Moon.astro';
// Definición local de los enlaces de navegación
const NAV_LINKS = [
  { label: 'Proyectos', href: '#projects' },
  { label: 'Experiencia', href: '#experience' },
  { label: 'Stack', href: '#stack' },
  { label: 'Sobre mí', href: '#about' },
];
---

<div class="relative w-full h-20 opacity-30 pointer-events-none"></div>

<header
  id="header"
  class="fixed top-0 z-50 w-full h-20 bg-white/80 dark:bg-black/80 backdrop-blur-md transition-colors duration-300">
  <div
    class="flex items-center justify-between h-full max-w-5xl mx-auto px-6 border-b border-transparent dark:border-neutral-800 lg:rounded-b-xl">
    <Logo />

    <div
      id="mobileMenuBackground"
      class="fixed inset-0 z-20 hidden w-screen h-screen bg-white/90 dark:bg-neutral-950/90 backdrop-blur-sm transition-opacity duration-300">
    </div>

    <nav
      class="relative z-30 flex items-center justify-end flex-grow text-sm font-medium">
      <button
        id="menuToggle"
        aria-label="Abrir menú de navegación"
        class="flex items-center justify-center w-8 h-8 ml-4 cursor-pointer sm:hidden text-neutral-600 dark:text-neutral-200">
        <svg
          id="openIcon"
          class="w-8 h-8"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 8h16M4 16h16"></path></svg
        >
        <svg
          id="closeIcon"
          class="hidden w-7 h-7"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path></svg
        >
      </button>

      <div
        id="menu"
        class="fixed top-[80px] left-0 z-40 hidden w-full pb-6 flex-col items-center bg-white dark:bg-neutral-950 sm:relative sm:top-0 sm:flex sm:flex-row sm:w-auto sm:pb-0 sm:bg-transparent sm:dark:bg-transparent">
        {
          NAV_LINKS.map((link) => (
            <a
              href={link.href}
              class="nav-link relative w-full px-4 py-3 text-center transition-colors duration-200 sm:w-auto sm:py-0 text-neutral-500 hover:text-blue-600 dark:text-neutral-400 dark:hover:text-blue-400">
              {link.label}
            </a>
          ))
        }
      </div>

      <button
        id="darkToggle"
        aria-label="Cambiar tema de color"
        class="relative flex items-center ml-6 group focus:outline-none">
        <div
          class="flex items-center justify-center w-9 h-9 rounded-lg bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 transition-all hover:ring-2 hover:ring-blue-500">
          <div id="sunIcon" class="hidden dark:block text-yellow-400">
            <Sun />
          </div>
          <div id="moonIcon" class="block dark:hidden text-blue-600">
            <Moon />
          </div>
        </div>
      </button>
    </nav>
  </div>
</header>

<script>
  function setupNavbar() {
    const menuToggle = document.getElementById('menuToggle');
    const menu = document.getElementById('menu');
    const bg = document.getElementById('mobileMenuBackground');
    const openIcon = document.getElementById('openIcon');
    const closeIcon = document.getElementById('closeIcon');
    const darkToggle = document.getElementById('darkToggle');

    // Lógica del Menú Móvil
    const toggleMenu = () => {
      const isHidden = menu?.classList.toggle('hidden');
      bg?.classList.toggle('hidden');
      openIcon?.classList.toggle('hidden');
      closeIcon?.classList.toggle('hidden');
      document.body.style.overflow = isHidden ? 'auto' : 'hidden';
    };

    menuToggle?.addEventListener('click', toggleMenu);
    bg?.addEventListener('click', toggleMenu);

    // Cerrar menú al hacer click en un link
    document.querySelectorAll('.nav-link').forEach((link) => {
      link.addEventListener('click', () => {
        if (window.innerWidth < 640) toggleMenu();
      });
    });

    // Lógica de Modo Oscuro sincronizada con Layout base
    darkToggle?.addEventListener('click', () => {
      const isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('dark_mode', isDark.toString());
    });
  }

  // Ejecutar en carga inicial y después de cada transición de página
  document.addEventListener('astro:page-load', setupNavbar);
</script>

<style>
  /* Clase para resaltar el link activo (se gestiona desde SectionContainer.astro) */
  .nav-link.active {
    @apply text-blue-600 dark:text-blue-400 font-bold;
  }
</style>
