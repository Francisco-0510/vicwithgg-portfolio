---
import Logo from '../components/logo.astro';
import Moon from './icons/Moon.astro';
import Sun from './icons/sun.astro';

const NAV_LINKS = [
  { label: 'Proyectos', href: '#projects' },
  { label: 'Experiencia', href: '#experience' },
  { label: 'Stack', href: '#stack' },
  { label: 'Sobre mí', href: '#about' },
];
---

<div class="w-full h-20 opacity-0 pointer-events-none" aria-hidden="true"></div>

<header
  id="header"
  class="fixed top-0 z-50 w-full h-20 transition-all duration-300">
  <div
    class="flex items-center justify-between h-full max-w-5xl mx-auto px-6 border-b border-transparent transition-all duration-300 lg:rounded-b-xl">
    <Logo />

    <div
      id="mobileMenuBackground"
      class="fixed inset-0 z-20 hidden w-screen h-screen bg-white/95 dark:bg-neutral-950/95 backdrop-blur-md opacity-0 transition-opacity duration-300">
    </div>

    <nav
      class="relative z-30 flex items-center justify-end flex-grow text-sm font-medium"
      aria-label="Navegación principal">
      <div class="flex items-center sm:hidden">
        <button
          id="openMenu"
          aria-label="Abrir menú de navegación"
          aria-expanded="false"
          aria-controls="menu"
          class="flex items-center justify-center w-10 h-10 text-neutral-600 dark:text-neutral-200 focus:outline-none">
          <svg
            class="w-8 h-8"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 8h16M4 16h16"></path>
          </svg>
        </button>

        <button
          id="closeMenu"
          aria-label="Cerrar menú de navegación"
          class="hidden items-center justify-center w-10 h-10 text-neutral-600 dark:text-neutral-200 focus:outline-none">
          <svg
            class="w-8 h-8"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>

      <div
        id="menu"
        class="fixed top-[75px] left-0 z-40 hidden w-full pb-8 flex-col items-center bg-white dark:bg-neutral-950 shadow-2xl sm:relative sm:top-0 sm:flex sm:flex-row sm:w-auto sm:pb-0 sm:bg-transparent sm:dark:bg-transparent sm:shadow-none">
        {
          NAV_LINKS.map((link) => (
            <a
              href={link.href}
              class="nav-link w-full px-6 py-4 text-center text-base sm:text-sm transition-colors duration-200 sm:w-auto sm:py-0 text-neutral-500 hover:text-blue-600 dark:text-neutral-400 dark:hover:text-blue-400 font-medium">
              {link.label}
            </a>
          ))
        }
      </div>

      <button
        id="darkToggle"
        aria-label="Cambiar tema de color"
        class="group relative ml-4 flex items-center justify-center w-10 h-10 rounded-xl bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 transition-all hover:border-blue-500/50 focus:ring-2 focus:ring-blue-500 focus:outline-none">
        <div
          class="horizon relative w-6 h-6 flex items-center justify-center overflow-hidden">
          <div
            id="sun"
            class="absolute transition-all duration-500 text-yellow-500">
            <Sun class="w-6 h-6" />
          </div>
          <div
            id="moon"
            class="absolute transition-all duration-500 hidden text-blue-500 dark:text-blue-400">
            <Moon class="w-6 h-6" />
          </div>
        </div>
      </button>
    </nav>
  </div>
</header>

<style>
  /* Efecto Glassmorphism al hacer scroll (Inyectado por JS) */
  #header.fixed {
    @apply h-14;
  }

  #header.fixed > div {
    @apply bg-white/80 dark:bg-neutral-900/80 backdrop-blur-2xl border-neutral-200/50 dark:border-neutral-800/50 shadow-sm;
  }

  /* Ajustes para la experiencia móvil */
  @media (max-width: 640px) {
    #menu {
      height: calc(100vh - 75px);
      justify-content: center;
      @apply bg-white dark:bg-neutral-950;
    }
  }

  /* Animación sutil para los links */
  .nav-link {
    position: relative;
  }

  @media (min-width: 640px) {
    .nav-link::after {
      content: '';
      @apply absolute bottom-[-4px] left-0 w-0 h-[2px] bg-blue-500 transition-all duration-300;
    }
    .nav-link:hover::after {
      @apply w-full;
    }
  }
</style>
