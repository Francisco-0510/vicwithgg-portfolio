---
interface Props {
  title: string;
  description?: string;
  class?: string;
}

const { title, description, class: className } = Astro.props;
---

<div class:list={['max-w-2xl space-y-3', className]}>
  <h2
    class="text-balance text-3xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100 md:text-4xl">
    {title}
  </h2>

  {
    description && (
      <p class="text-pretty text-base font-normal leading-relaxed text-neutral-600 dark:text-neutral-400 md:text-lg">
        {description}
      </p>
    )
  }
</div>
