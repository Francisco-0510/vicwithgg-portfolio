---
interface Props {
  title?: string;
  description?: string;
}

const { title: propTitle, description: propDescription } = Astro.props;

// Datos base extraídos de tu CV y configuración anterior
const SITE_DATA = {
  defaultTitle: 'VicWithGG Portfolio Web',
  defaultDescription:
    'Apasionado Diseñador UX/UI y Desarrollador Web comprometido con crear experiencias digitales que destaquen.',
  url: 'https://vicwithgg-designer.netlify.app/',
  image: '/assets/images/me.jpg', // Ruta relativa desde la raíz (carpeta public)
  twitterHandle: '@VicWithGG1',
  author: 'Francisco Victorico Aguirre Jiménez',
  keywords:
    'UX/UI Design, web development, web design, responsive design, frontend development, website creation, creative projects, freelance web developer, portfolio web design, digital design, custom web solutions, Francisco Victorico Aguirre Jimenez, VicWithGG, Francisco Aguirre Jimenez, Oaxaca',
};

// Determinar qué contenido mostrar
const metadata = {
  title: propTitle
    ? `${propTitle} | ${SITE_DATA.defaultTitle}`
    : SITE_DATA.defaultTitle,
  description: propDescription || SITE_DATA.defaultDescription,
  url: SITE_DATA.url,
  image: new URL(SITE_DATA.image, SITE_DATA.url).toString(),
};
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<link rel="icon" type="image/svg+xml" href="/iconVGG.svg" />
<meta name="generator" content={Astro.generator} />
<meta name="author" content={SITE_DATA.author} />
<meta name="keywords" content={SITE_DATA.keywords} />

<title>{metadata.title}</title>
<meta name="title" content={metadata.title} />
<meta name="description" content={metadata.description} />
<link rel="canonical" href={metadata.url} />

<meta property="og:type" content="website" />
<meta property="og:url" content={metadata.url} />
<meta property="og:title" content={metadata.title} />
<meta property="og:description" content={metadata.description} />
<meta property="og:image" content={metadata.image} />
<meta property="og:site_name" content={SITE_DATA.defaultTitle} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={metadata.url} />
<meta name="twitter:domain" content="vicwithgg-designer.netlify.app" />
<meta name="twitter:title" content={metadata.title} />
<meta name="twitter:description" content={metadata.description} />
<meta name="twitter:image" content={metadata.image} />
<meta name="twitter:site" content={SITE_DATA.twitterHandle} />
<meta name="twitter:creator" content={SITE_DATA.twitterHandle} />

<script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Francisco Victorico Aguirre Jiménez",
    "jobTitle": "Diseñador UX/UI y Desarrollador Web",
    "url": "https://vicwithgg-designer.netlify.app/",
    "image": "https://vicwithgg-designer.netlify.app/assets/images/me.jpg",
    "sameAs": [
      "https://x.com/VicWithGG1",
      "https://github.com/Francisco-0510",
      "https://www.linkedin.com/in/vicwith-gg/",
      "https://www.facebook.com/vicwithGG",
      "https://www.tiktok.com/@vicwithgg",
      "https://www.figma.com/@vicwithgg",
      "https://www.instagram.com/vicwithgg/"
    ]
  }
</script>

<script is:inline>
  const getTheme = () => {
    if (
      typeof localStorage !== 'undefined' &&
      localStorage.getItem('dark_mode')
    ) {
      return localStorage.getItem('dark_mode') === 'true';
    }
    return window.matchMedia('(prefers-color-scheme: dark)').matches;
  };

  if (getTheme()) {
    document.documentElement.classList.add('dark');
  } else {
    document.documentElement.classList.remove('dark');
  }
</script>

<style>
  .prose img {
    border-radius: 20px;
  }
</style>
