---
interface Props {
  logo: string;
  dates: string;
  role: string;
  company: string;
  description: string;
  skills?: string[];
}

const { logo, dates, role, company, description, skills } = Astro.props;
---

<div
  class="relative flex flex-col justify-start pl-12 pb-10 border-l border-gray-300 dark:border-neutral-700">
  <div
    class="absolute top-0 left-0 z-40 flex items-center justify-center -translate-x-1/2 bg-white border rounded-full w-14 h-14 dark:bg-neutral-950 border-neutral-300 dark:border-neutral-700 overflow-hidden p-1.5">
    <img
      src={logo}
      alt={`Logo de ${company}`}
      class="w-full h-full object-contain rounded-full"
    />
  </div>

  <header class="mb-4">
    <h3
      class="text-pretty text-lg font-header font-semibold text-neutral-900 dark:text-neutral-50">
      {role}
    </h3>

    <div
      class="mt-1 text-pretty text-sm font-semibold text-neutral-600 dark:text-neutral-300 transition-colors duration-200">
      <span>{company}</span>
      <span class="opacity-50 mx-1"> | </span>
      <span class="opacity-80">
        <time>{dates}</time>
      </span>
    </div>
  </header>

  <div class="mb-4">
    <p
      class="text-sm text-pretty text-neutral-700 dark:text-neutral-300 leading-relaxed">
      {description}
    </p>
  </div>

  {
    skills && skills.length > 0 && (
      <footer class="flex flex-wrap gap-2 mt-2">
        {skills.map((skill) => (
          <span class="inline-flex items-center rounded-full border border-neutral-200 dark:border-neutral-700 px-2.5 py-0.5 text-xs font-semibold text-neutral-800 dark:text-neutral-200 bg-neutral-100 dark:bg-neutral-800/50 transition-colors hover:bg-neutral-200 dark:hover:bg-neutral-800">
            {skill}
          </span>
        ))}
      </footer>
    )
  }
</div>
