---
// src/components/ui/ProjectCard.astro
import type { Project } from '../../data/portfolio';

interface Props {
  project: Project;
  index?: number;
}

const { project, index = 0 } = Astro.props;
const delay = index % 3; // cycle 0-1-2
---

<a
  href={project.links.live || project.links.figma || project.links.github || '#'}
  class={`project-card reveal reveal-delay-${delay}`}
  target={project.links.live ? '_blank' : undefined}
  rel={project.links.live ? 'noopener noreferrer' : undefined}
  aria-label={`Ver proyecto: ${project.name}`}
>
  <!-- Thumbnail -->
  <div class="project-thumbnail">
    <img
      src={project.thumbnail}
      alt={`Thumbnail de ${project.name}`}
      loading="lazy"
      width="400"
      height="200"
      onerror="this.style.display='none'"
    />
    <div class="project-thumbnail-overlay"></div>
    <div class="project-type-badge">{project.type}</div>
  </div>

  <!-- Content -->
  <div class="project-content">
    <div class="project-sector">{project.sector}</div>
    <h3 class="project-name">{project.name}</h3>
    <p class="project-desc">{project.description}</p>

    <!-- Tech chips -->
    <div class="project-tech" role="list" aria-label="Tecnologías">
      {project.tech.map((t) => (
        <span class="tech-chip" role="listitem">{t}</span>
      ))}
    </div>

    <!-- Links -->
    <div class="project-links">
      {project.links.live && (
        <span class="project-link">
          Live
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
            <polyline points="15 3 21 3 21 9" />
            <line x1="10" y1="14" x2="21" y2="3" />
          </svg>
        </span>
      )}
      {project.links.figma && (
        <span class="project-link blue">
          Figma
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </span>
      )}
      {project.links.github && (
        <span class="project-link">
          GitHub
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </span>
      )}
    </div>
  </div>

  <!-- Background decorative text -->
  <div class="project-bg-text" aria-hidden="true">{project.name.split(' ')[0].toUpperCase()}</div>
</a>

<style>
  .project-card {
    background: var(--bg);
    display: flex;
    flex-direction: column;
    min-height: 420px;
    transition: background 0.3s;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    text-decoration: none;
  }
  .project-card::before {
    content: '';
    position: absolute;
    bottom: 0; left: 0;
    width: 100%; height: 2px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
    z-index: 2;
  }
  .project-card:hover { background: var(--bg-card); }
  .project-card:hover::before { transform: scaleX(1); }

  /* Thumbnail */
  .project-thumbnail {
    width: 100%; height: 200px;
    background: var(--bg-card);
    display: flex; align-items: center; justify-content: center;
    overflow: hidden; position: relative;
  }
  .project-thumbnail img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .project-card:hover .project-thumbnail img { transform: scale(1.08); }

  .project-thumbnail-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, var(--bg) 0%, transparent 70%);
    opacity: 0.7; z-index: 1;
  }

  .project-type-badge {
    position: absolute;
    top: 12px; right: 12px;
    font-family: var(--f-mono);
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 4px 10px;
    background: rgba(6, 8, 13, 0.8);
    border: 1px solid var(--line);
    color: var(--text-3);
    z-index: 2;
    backdrop-filter: blur(4px);
  }

  /* Content */
  .project-content {
    padding: 24px 28px;
    display: flex; flex-direction: column;
    gap: 12px; flex: 1;
    position: relative; z-index: 2;
  }

  .project-sector {
    font-family: var(--f-mono);
    font-size: 9px; letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .project-name {
    font-family: var(--f-display);
    font-size: 20px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.03em;
    color: var(--text); line-height: 1.1;
  }
  .project-desc {
    font-size: 14px; color: var(--text-2);
    line-height: 1.6; flex: 1;
  }
  .project-tech {
    display: flex; gap: 6px; flex-wrap: wrap; margin-top: 4px;
  }

  /* Links */
  .project-links {
    display: flex; gap: 12px; margin-top: 8px;
  }
  .project-link {
    font-family: var(--f-mono);
    font-size: 10px; letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    display: inline-flex; align-items: center; gap: 4px;
    transition: gap 0.2s, color 0.2s;
  }
  .project-link.blue { color: var(--blue); }
  .project-card:hover .project-link { gap: 8px; }
  .project-link svg { width: 12px; height: 12px; }

  /* Decorative bg text */
  .project-bg-text {
    position: absolute;
    bottom: -8px; right: 8px;
    font-family: var(--f-display);
    font-size: 64px; font-weight: 900;
    line-height: 1; color: transparent;
    -webkit-text-stroke: 1px rgba(237, 233, 224, 0.04);
    pointer-events: none; user-select: none;
    letter-spacing: -0.02em; z-index: 1;
  }
</style>
