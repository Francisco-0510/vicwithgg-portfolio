---
import Figma from '@components/icons/Figma.astro';
import GitHub from '@components/icons/GitHub.astro';
import Linkedin from '@components/icons/Linkedin.astro';
import { Image } from 'astro:assets';
import Download from './icons/Download.astro';
import ProjectBrief from './icons/ProjectBrief.astro';
import X from './icons/X.astro';
---

<section class="relative min-h-full flex flex-col justify-center pt-14 pb-16">
  <div class="max-w-4xl mx-auto w-full px-6 lg:px-8 flex flex-col gap-8">
    <header
      class="flex flex-col md:flex-row md:items-end justify-between gap-6">
      <div class="flex flex-col gap-y-4">
        <h2
          class="text-2xl md:text-3xl font-semibold text-neutral-900 dark:text-white text-pretty">
          ¡Hola! Soy Francisco Victorico Aguirre Jiménez
        </h2>

        <div
          class="flex items-center gap-6 text-neutral-600 dark:text-neutral-400">
          <a
            href="https://github.com/Francisco-0510"
            target="_blank"
            rel="noreferrer"
            aria-label="Perfil de GitHub"
            class="hover:text-neutral-900 dark:hover:text-white transition-colors">
            <GitHub class="w-6 h-6" />
          </a>
          <a
            href="https://www.linkedin.com/in/vicwith-gg/"
            target="_blank"
            rel="noreferrer"
            aria-label="Perfil de LinkedIn"
            class="hover:text-neutral-900 dark:hover:text-white transition-colors">
            <Linkedin class="w-6 h-6" />
          </a>
          <a
            href="https://www.figma.com/@vicwithgg"
            target="_blank"
            rel="noreferrer"
            aria-label="Perfil de Figma"
            class="hover:text-neutral-900 dark:hover:text-white transition-colors">
            <Figma class="w-6 h-6" />
          </a>
          <a
            href="https://x.com/VicWithGG1"
            target="_blank"
            rel="noreferrer"
            aria-label="Perfil de X (Twitter)"
            class="hover:text-neutral-900 dark:hover:text-white transition-colors">
            <X class="w-6 h-6" />
          </a>
        </div>
      </div>

      <Image
        src="/assets/images/me.jpg"
        alt="Fotografía de Francisco Victorico Aguirre Jiménez"
        width={96}
        height={96}
        loading="eager"
        decoding="sync"
        class="hidden md:block w-24 h-24 rounded-full bg-neutral-200 dark:bg-neutral-800 object-cover shadow-sm"
      />
    </header>

    <div
      class="text-4xl sm:text-5xl lg:text-7xl font-bold tracking-tight text-neutral-900 dark:text-white text-balance">
      <span
        class="bg-gradient-to-r from-blue-600 to-cyan-500 bg-clip-text text-transparent">
        Diseñador UX/UI
      </span>
      <br class="hidden sm:block" />
      & Desarrollador Web
    </div>

    <p
      class="max-w-[750px] text-lg sm:text-xl text-neutral-700 dark:text-neutral-300 text-pretty leading-relaxed">
      Apasionado <strong class="text-blue-600 dark:text-blue-400 font-semibold"
        >Diseñador UX/UI</strong
      > y <strong class="text-blue-600 dark:text-blue-400 font-semibold"
        >Desarrollador Web</strong
      > enfocado en crear experiencias digitales excepcionales. Mi objetivo es lograr
      un equilibrio perfecto entre las necesidades de los usuarios y los objetivos
      del producto.
    </p>

    <div class="flex flex-wrap items-center gap-4 pt-4">
      <a
        href="#projects"
        class="inline-flex h-12 items-center justify-center gap-2 rounded-lg bg-blue-600 px-8 text-sm font-medium text-white transition-all duration-300 hover:bg-blue-700 hover:shadow-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-neutral-950">
        <ProjectBrief class="w-5 h-5" />
        Mis Trabajos
      </a>
      <a
        href="/assets/CV _ AGUIRRE JIMENEZ FRANCISCO VICTORICO.pdf"
        target="_blank"
        rel="noreferrer"
        download="Francisco_Aguirre_CV.pdf"
        class="inline-flex h-12 items-center justify-center gap-2 rounded-lg border border-neutral-200 bg-white/50 backdrop-blur px-8 text-sm font-medium text-neutral-900 transition-all duration-300 hover:bg-neutral-50 hover:shadow-sm focus:outline-none focus:ring-2 focus:ring-neutral-200 focus:ring-offset-2 dark:border-neutral-800 dark:bg-neutral-900/50 dark:text-white dark:hover:bg-neutral-800 dark:focus:ring-neutral-800 dark:focus:ring-offset-neutral-950">
        <Download class="w-5 h-5" />
        Descargar mi CV
      </a>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 hidden md:block">
    <a
      href="#featured"
      aria-label="Desplazarse a la siguiente sección"
      class="inline-flex w-10 h-10 animate-bounce items-center justify-center rounded-full text-neutral-500 hover:bg-neutral-100 hover:text-neutral-900 transition-colors dark:text-neutral-400 dark:hover:bg-neutral-800 dark:hover:text-white focus:outline-none focus:ring-2 focus:ring-neutral-200 dark:focus:ring-neutral-800">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="w-6 h-6">
        <path d="m6 9 6 6 6-6"></path>
      </svg>
    </a>
  </div>
</section>
